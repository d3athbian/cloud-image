{
  "name": "@cloudimage/cloud",
  "version": "0.0.5",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.js"
    },
    "./register": {
      "import": "./dist/register.js"
    },
    "./debugger": {
      "types": "./dist/debugger/index.d.ts",
      "import": "./dist/debugger.js",
      "style": "./dist/debugger.css"
    },
    "./dist/cloud.css": {
      "import": "./dist/debugger.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "biome check src --write",
    "lint:check": "biome check src",
    "format": "biome format --write src",
    "format:check": "biome format src"
  },
  "peerDependencies": {
    "jotai": "^2.19.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.2.4",
    "terser": "^5.46.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
